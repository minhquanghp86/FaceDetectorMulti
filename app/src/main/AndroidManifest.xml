<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions: chỉ khai báo 1 lần mỗi loại -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>

    <!-- USB Serial: cho phép kết nối USB host (giữ tương thích repo gốc) -->
    <uses-feature android:name="android.hardware.usb.host" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">

        <!-- MainActivity: landscape + custom icon -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- SettingsActivity: giữ nguyên theme + metadata -->
        <activity
            android:name=".ui.SettingsActivity"
            android:label="⚙ Cài đặt"
            android:parentActivityName=".ui.MainActivity"
            android:theme="@style/Theme.AppCompat.DayNight.DarkActionBar">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".ui.MainActivity" />
        </activity>

        <!-- RegistrationActivity: giữ nguyên đầy đủ theme + metadata (chỉ 1 block) -->
        <activity
            android:name=".ui.RegistrationActivity"
            android:label="👤 Đăng ký face"
            android:parentActivityName=".ui.MainActivity"
            android:theme="@style/Theme.AppCompat.DayNight.DarkActionBar">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".ui.MainActivity" />
        </activity>

        <!-- ManageFacesActivity: giữ nguyên -->
        <activity
            android:name=".ui.ManageFacesActivity"
            android:label="📋 Quản lý faces"
            android:parentActivityName=".ui.MainActivity"/>

    </application>
</manifest>