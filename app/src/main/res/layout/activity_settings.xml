<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙ Cài đặt"
            android:textColor="#00FF50"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="16dp"/>

        <!-- ═══ SECTION: DETECTION ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📷  PHÁT HIỆN KHUÔN MẶT"
            android:textColor="#00AAFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="12dp"/>

        <!-- Min Face Size -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kích thước mặt tối thiểu (minFaceSize)"
            android:textColor="#CCCCCC"
            android:textSize="14sp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nhỏ hơn → detect xa hơn, tốn CPU hơn"
            android:textColor="#888888"
            android:textSize="12sp"
            android:paddingBottom="4dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <SeekBar
                android:id="@+id/seek_min_face_size"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="#00FF50"
                android:thumbTint="#00FF50"
                android:max="25"
                android:progress="5"/>
            <TextView
                android:id="@+id/tv_min_face_size_val"
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="end"
                android:paddingStart="8dp"
                android:text="0.10"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginVertical="16dp"/>

        <!-- Accurate Mode -->
        <Switch
            android:id="@+id/switch_perf_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chế độ Accurate (chính xác hơn, chậm hơn — cần restart camera)"
            android:textOn="BẬT - Chính xác cao"
            android:textOff="TẮT - Ưu tiên tốc độ"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:thumbTint="#00FF50"
            android:trackTint="@color/switch_track"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginVertical="16dp"/>

        <!-- Resolution -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Độ phân giải camera (cần restart camera)"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:paddingBottom="8dp"/>
        <RadioGroup
            android:id="@+id/rg_resolution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <RadioButton
                android:id="@+id/rb_res_640"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="640×480  (nhanh nhất, tiết kiệm pin)"
                android:textColor="#CCCCCC"
                android:buttonTint="#00FF50"/>
            <RadioButton
                android:id="@+id/rb_res_1280"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1280×720  (cân bằng — khuyến nghị)"
                android:textColor="#CCCCCC"
                android:buttonTint="#00FF50"
                android:checked="true"/>
            <RadioButton
                android:id="@+id/rb_res_1920"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1920×1080  (chi tiết nhất, tốn CPU)"
                android:textColor="#CCCCCC"
                android:buttonTint="#00FF50"/>
        </RadioGroup>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginVertical="16dp"/>

        <!-- Frame Interval -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Khoảng cách frame xử lý (ms)"
            android:textColor="#CCCCCC"
            android:textSize="14sp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 = xử lý tất cả frame | 50ms = \~20fps | 100ms = \~10fps"
            android:textColor="#888888"
            android:textSize="12sp"
            android:paddingBottom="4dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <SeekBar
                android:id="@+id/seek_frame_interval"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="#00FF50"
                android:thumbTint="#00FF50"
                android:max="200"
                android:progress="50"/>
            <TextView
                android:id="@+id/tv_frame_interval_val"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="end"
                android:paddingStart="8dp"
                android:text="50ms"/>
        </LinearLayout>

        <!-- ═══ SECTION: MQTT ═══ -->
        <View android:layout_width="match_parent" android:layout_height="2dp"
            android:background="#00AAFF" android:layout_marginVertical="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📡  KẾT NỐI MQTT"
            android:textColor="#00AAFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="4dp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đẩy kết quả phát hiện khuôn mặt lên broker MQTT theo thời gian thực."
            android:textColor="#888888"
            android:textSize="12sp"
            android:paddingBottom="12dp"/>

        <!-- Enable MQTT -->
        <Switch
            android:id="@+id/switch_mqtt_enabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bật MQTT"
            android:textOn="✅ MQTT ĐÃ BẬT"
            android:textOff="❌ MQTT TẮT"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:thumbTint="#00FF88"
            android:trackTint="@color/switch_track"
            android:paddingBottom="16dp"/>

        <!-- Broker URL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Broker URL"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:paddingBottom="4dp"/>
        <EditText
            android:id="@+id/et_mqtt_broker"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#2A2A2A"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:hint="tcp://192.168.1.100:1883"
            android:textColorHint="#555555"
            android:inputType="textUri"
            android:padding="10dp"
            android:text="tcp://192.168.1.100:1883"
            android:singleLine="true"
            android:layout_marginBottom="12dp"/>

        <!-- Username -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Username (để trống nếu không có xác thực)"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:paddingBottom="4dp"/>
        <EditText
            android:id="@+id/et_mqtt_username"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#2A2A2A"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:hint="username"
            android:textColorHint="#555555"
            android:inputType="text"
            android:padding="10dp"
            android:singleLine="true"
            android:layout_marginBottom="12dp"/>

        <!-- Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:paddingBottom="4dp"/>
        <EditText
            android:id="@+id/et_mqtt_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#2A2A2A"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:hint="password"
            android:textColorHint="#555555"
            android:inputType="textPassword"
            android:padding="10dp"
            android:singleLine="true"
            android:layout_marginBottom="12dp"/>

        <!-- Topic -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Topic"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:paddingBottom="4dp"/>
        <EditText
            android:id="@+id/et_mqtt_topic"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#2A2A2A"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:hint="face/detection"
            android:textColorHint="#555555"
            android:inputType="text"
            android:padding="10dp"
            android:text="face/detection"
            android:singleLine="true"
            android:layout_marginBottom="12dp"/>

        <!-- QoS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="QoS"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:paddingBottom="4dp"/>
        <RadioGroup
            android:id="@+id/rg_mqtt_qos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rb_qos_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QoS 0 (nhanh nhất)"
                android:textColor="#CCCCCC"
                android:buttonTint="#00AAFF"
                android:checked="true"
                android:layout_marginEnd="12dp"/>
            <RadioButton
                android:id="@+id/rb_qos_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QoS 1"
                android:textColor="#CCCCCC"
                android:buttonTint="#00AAFF"
                android:layout_marginEnd="12dp"/>
            <RadioButton
                android:id="@+id/rb_qos_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QoS 2"
                android:textColor="#CCCCCC"
                android:buttonTint="#00AAFF"/>
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Payload mẫu: {&quot;ts&quot;:1234567890,&quot;count&quot;:1,&quot;ms&quot;:45,&quot;faces&quot;:[{&quot;id&quot;:1,&quot;left&quot;:0.12,&quot;top&quot;:0.20,&quot;right&quot;:0.38,&quot;bottom&quot;:0.68,&quot;cx&quot;:0.25,&quot;cy&quot;:0.44,&quot;w&quot;:0.26,&quot;h&quot;:0.48}]}"
            android:textColor="#666666"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"/>
  
        <!-- ═══ Reset ═══ -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#333333" android:layout_marginVertical="16dp"/>

        <Button
            android:id="@+id/btn_reset_defaults"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="↺  Reset về mặc định"
            android:textColor="#FF4444"
            android:backgroundTint="#2A1010"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ Cài đặt lưu tự động. Thay đổi Resolution/Accurate Mode cần restart camera."
            android:textColor="#666666"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingBottom="20dp"/>

    </LinearLayout>
</ScrollView>