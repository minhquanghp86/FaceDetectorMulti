<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.FaceDetectorMulti" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorPrimaryDark">@color/brand_dark</item>
        <item name="colorAccent">@color/brand_blue</item>
        <item name="android:statusBarColor">@color/brand_dark</item>
        <item name="android:navigationBarColor">@color/brand_dark</item>
    </style>
    
    <!-- Dark theme for Settings/Registration -->
    <style name="Theme.FaceDetectorMulti.Dark" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorPrimaryDark">@color/brand_dark</item>
        <item name="colorAccent">@color/brand_blue</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>
</resources>
